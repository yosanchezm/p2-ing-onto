# ── API Keys — copia este archivo como .env y rellena tus claves ─────────────
# Obtener en: https://aistudio.google.com → API Keys
GOOGLE_API_KEY=tu_clave_aqui

# Obtener en: https://console.groq.com → API Keys
GROQ_API_KEY=tu_clave_aqui

# Obtener en: https://smith.langchain.com → Settings → API Keys
LANGCHAIN_API_KEY=tu_clave_aqui
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=RAG-KnowledgeGraph-P2

# Obtener en: https://app.tavily.com → API Keys
TAVILY_API_KEY=tu_clave_aqui

# ── GraphDB ───────────────────────────────────────────────────────────────────
GRAPHDB_BASE=http://localhost:7200
GRAPHDB_REPO=biomed-kg
